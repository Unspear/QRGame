    "http-server": "^14.1.1",
    "mini-css-extract-plugin": "^2.10.0",
    "style-loader": "^4.0.0",
    "webpack": "^5.102.1",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.2",
    "webpack-pwa-manifest": "^4.3.0",
    "workbox-webpack-plugin": "^7.4.0"
  },
  "dependencies": {
    "@codemirror/legacy-modes": "^6.5.2",
    "brotli-wasm": "^3.0.1",
