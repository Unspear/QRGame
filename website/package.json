{
  "name": "qrgame",
  "version": "1.0.0",
  "repository": {
    "url": "git+https://github.com/CyborgCabbage/QRGame.git"
  },
  "private": true,
  "scripts": {
    "//": "Single ampersand is used because the mkdir will fail if it already exists, this may not work right on UNIX",
    "buildcpp": "mkdir cmake-build & cd cmake-build & emcmake cmake .. -DCMAKE_BUILD_TYPE=Release & cmake --build . & cd ..",
    "build": "webpack --mode=development",
    "start": "http-server dist",
    "test": "npm run build && npm run start",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist --cname qr.unspear.com --nojekyll"
  },
  "author": "",
